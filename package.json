{
  "name": "nexusrealtime-kitbuilder02",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Custom kit factory for NexusRealtime peer rooms, host layers, live mirrors, Cloudflare tunnels, and secure ONNX orchestration.",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "smoke": "node apps/fabric-lab/src/main.js",
    "check": "npm run kit:check && npm test && npm run smoke",
    "kit:intake": "node scripts/kit-intake.mjs",
    "kit:advance": "node scripts/kit-advance.mjs",
    "kit:state": "node scripts/kit-state.mjs",
    "kit:doctor": "node scripts/kitbuilder-doctor.mjs",
    "kit:examples": "node scripts/check-kit-examples.mjs",
    "kit:registry": "node scripts/build-kit-registry.mjs",
    "kit:check": "node scripts/validate-kits.mjs",
    "kit:issue": "node scripts/kit-issue.mjs",
    "kit:lesson": "node scripts/agent-brain-lesson.mjs",
    "live:server": "node kits/live-server-kit/bin/start-server.js --port 8787",
    "live:tunnel": "node kits/cloudflare-tunnel-kit/bin/start-quick-tunnel.js --url http://127.0.0.1:8787",
    "live:fabric": "node apps/live-fabric-runner/start.js",
    "live:doctor": "node apps/live-fabric-runner/doctor.js"
  },
  "keywords": ["nexusrealtime", "kitbuilder", "peerjs", "webrtc", "onnx", "cloudflare-tunnel", "live-server", "agent-mesh", "protokit"],
  "license": "MIT"
}
